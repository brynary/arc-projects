+function raySegmentIntersect(ox, oz, dx, dz, ax, az, bx, bz) {
+  const sx = bx - ax;
+  const sz = bz - az;
+  const denom = dx * sz - dz * sx;
+  if (Math.abs(denom) < 1e-8) return null; // parallel
+
+  const t = ((ax - ox) * sz - (az - oz) * sx) / denom;
+  const u = ((ax - ox) * dz - (az - oz) * dx) / denom;
